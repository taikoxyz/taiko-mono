{
  "$id": "configuredRelayer.json",
  "type": "object",
  "properties": {
    "configuredRelayer": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "chainIds": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "url": {
            "type": "string",
            "pattern": "^https?://(?![^\\s/?#@]*@)[A-Za-z0-9.-]+(?::[0-9]+)?(?:[/?#][^\\s]*)?$"
          }
        },
        "required": ["chainIds", "url"],
        "additionalProperties": false
      }
    }
  },
  "required": ["configuredRelayer"],
  "additionalProperties": false
}
