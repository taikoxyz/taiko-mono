---
import PageActions from "~/components/PageActions.astro";

interface Props {
  markdownUrl: string;
}

const { markdownUrl } = Astro.props;
---

<PageActions
  primaryAction={{
    kind: "copy",
    label: "Copy markdown",
    sourceUrl: markdownUrl,
  }}
  menuActions={[
    {
      kind: "copy",
      label: "Copy page as Markdown",
      sourceUrl: markdownUrl,
    },
    {
      kind: "link",
      label: "Open Markdown",
      href: markdownUrl,
      newTab: true,
    },
  ]}
  rootClassName="sl-markdown-actions"
  translateY="-0.4rem"
/>
