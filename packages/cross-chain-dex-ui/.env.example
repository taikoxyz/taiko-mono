# L1 RPC URL (for reading balances, creating smart wallet)
VITE_L1_RPC_URL=

# L2 RPC URL (for reading DEX reserves)
VITE_L2_RPC_URL=

# Builder RPC URL (for sending UserOps)
VITE_BUILDER_RPC_URL=http://localhost:4545

# Chain ID for L1
VITE_CHAIN_ID=31337

# Contract addresses (update after deployment)
VITE_USER_OPS_FACTORY=0x0000000000000000000000000000000000000000
VITE_L1_VAULT=0x0000000000000000000000000000000000000000
VITE_USDC_TOKEN=0x0000000000000000000000000000000000000000
VITE_SIMPLE_DEX=0x0000000000000000000000000000000000000000

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here
