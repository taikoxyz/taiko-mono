{
  "permissions": {
    "allow": [
      "WebFetch",
      "Bash(gh issue view:*)",
      "Bash(gh commit:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(find:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(mkdir:*)",
      "Bash(grep:*)",
      "Bash(pnpm compile:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm snapshot:*)",
      "Bash(pnpm layout:*)",
      "Bash(forge test:*)",
      "Bash(forge build:*)",
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(sed *)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Read(.env*)",
      "Read(*keystore-pw*)",
      "Bash(cat *keystore-pw*)",
      "Bash(xxd *keystore-pw*)",
      "Bash(head *keystore-pw*)",
      "Bash(tail *keystore-pw*)",
      "Bash(less *keystore-pw*)",
      "Bash(more *keystore-pw*)",
      "Bash(wc *keystore-pw*)",
      "Bash(od *keystore-pw*)",
      "Bash(hexdump *keystore-pw*)"
    ]
  }
}
